---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactLinks from '../components/ContactLinks.astro';
import BlogExplorer from '../components/BlogExplorer.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="首页" description="Haoping 的个人博客——记录 AI 领域的学习、思考与实践">
  <Header slot="header" />

  <section class="border-b border-[var(--color-border-subtle)]">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
      <h1 class="font-display max-w-3xl text-4xl font-normal leading-[1.15] tracking-tight md:text-5xl lg:text-[3.25rem]">
        你好，我是 Haoping
      </h1>
      <div class="mt-6 max-w-2xl space-y-4 text-lg leading-relaxed text-[var(--color-muted)]">
        <p>
          目前在华为从事 AI Agent 方向的工作。AI 领域日新月异，新想法、新方法层出不穷，我对其中很多方向都充满好奇。这个博客是我记录学习、思考、实践、分享的地方。我们一起进步！
        </p>
      </div>
      <div class="mt-8">
        <ContactLinks variant="prominent" />
      </div>
    </div>
  </section>

  <BlogExplorer posts={sortedPosts} />

  <Footer slot="footer" />
</BaseLayout>
