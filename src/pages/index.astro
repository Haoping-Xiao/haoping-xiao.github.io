---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = sortedPosts.slice(0, 3);
const allTags = [...new Set(sortedPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout title="Agent Notes" description="记录 AI Agent 领域的学习心得与探索思考">
  <Header slot="header" />

  <section class="border-b border-[var(--color-border-subtle)]">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
      <h1 class="font-display max-w-3xl text-4xl font-normal leading-[1.15] tracking-tight md:text-5xl lg:text-[3.25rem]">
        探索智能体的边界与可能
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-muted)]">
        在这里记录我在 AI Agent 领域的学习心得——从 ReAct 到 Tool Use，从多智能体协作到记忆系统，一步步构建对智能体的理解。
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="/blog"
          class="rounded-xl bg-[var(--color-text)] px-6 py-3 text-sm font-medium text-[var(--color-bg)] transition hover:bg-[var(--color-dark-surface)]"
        >
          阅读文章
        </a>
        <a
          href="/about"
          class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-3 text-sm font-medium text-[var(--color-text)] transition hover:bg-[var(--color-surface-elevated)]"
        >
          了解更多
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="mb-10 flex items-end justify-between gap-4">
      <div>
        <h2 class="font-display text-2xl font-medium tracking-tight">最新文章</h2>
        <p class="mt-2 text-sm text-[var(--color-muted)]">最近的学习记录</p>
      </div>
      <a
        href="/blog"
        class="shrink-0 text-sm font-medium text-[var(--color-accent)] transition hover:text-[var(--color-accent-hover)]"
      >
        查看全部 →
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  {
    allTags.length > 0 && (
      <section class="border-t border-[var(--color-border-subtle)] bg-[var(--color-surface)]">
        <div class="mx-auto max-w-6xl px-6 py-14">
          <h2 class="font-display mb-6 text-xl font-medium tracking-tight">探索主题</h2>
          <div class="flex flex-wrap gap-2">
            {allTags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full border border-[var(--color-border-subtle)] bg-[var(--color-bg)] px-4 py-2 text-sm text-[var(--color-muted)] transition hover:border-[var(--color-border)] hover:text-[var(--color-text)]"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <Footer slot="footer" />
</BaseLayout>
