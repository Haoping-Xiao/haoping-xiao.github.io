---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import ContactLinks from '../components/ContactLinks.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = sortedPosts.slice(0, 3);
const allTags = [...new Set(sortedPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout title="首页" description="Haoping 的个人博客——记录 AI 领域的学习、思考与实践">
  <Header slot="header" />

  <section class="border-b border-[var(--color-border-subtle)]">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
      <h1 class="font-display max-w-3xl text-4xl font-normal leading-[1.15] tracking-tight md:text-5xl lg:text-[3.25rem]">
        你好，我是 Haoping
      </h1>
      <div class="mt-6 max-w-2xl space-y-4 text-lg leading-relaxed text-[var(--color-muted)]">
        <p>
          目前在华为从事 AI Agent 方向的工作。AI 领域日新月异，新想法、新方法层出不穷，我对其中很多方向都充满好奇。
        </p>
        <p>
          这个博客是我记录学习、思考与实践总结的地方。把零散的想法写下来，往往能看到之前没注意到的连接。
        </p>
      </div>
      <div class="mt-8">
        <ContactLinks variant="prominent" />
      </div>
      <div class="mt-10">
        <a
          href="/blog"
          class="inline-flex rounded-xl bg-[var(--color-text)] px-6 py-3 text-sm font-medium text-[var(--color-bg)] transition hover:bg-[var(--color-dark-surface)]"
        >
          阅读文章
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="mb-10 flex items-end justify-between gap-4">
      <div>
        <h2 class="font-display text-2xl font-medium tracking-tight">最新文章</h2>
        <p class="mt-2 text-sm text-[var(--color-muted)]">最近的学习记录</p>
      </div>
      <a
        href="/blog"
        class="shrink-0 text-sm font-medium text-[var(--color-accent)] transition hover:text-[var(--color-accent-hover)]"
      >
        查看全部 →
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  {
    allTags.length > 0 && (
      <section class="border-t border-[var(--color-border-subtle)] bg-[var(--color-surface)]">
        <div class="mx-auto max-w-6xl px-6 py-14">
          <h2 class="font-display mb-6 text-xl font-medium tracking-tight">探索主题</h2>
          <div class="flex flex-wrap gap-2">
            {allTags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full border border-[var(--color-border-subtle)] bg-[var(--color-bg)] px-4 py-2 text-sm text-[var(--color-muted)] transition hover:border-[var(--color-border)] hover:text-[var(--color-text)]"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <Footer slot="footer" />
</BaseLayout>
