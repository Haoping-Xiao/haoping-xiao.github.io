---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
const { Content } = await render(post);

const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <article class="mx-auto max-w-3xl px-6 py-14 md:py-16">
    <header class="mb-12 space-y-5 border-b border-[var(--color-border-subtle)] pb-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-muted)] transition hover:text-[var(--color-accent)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        返回文章列表
      </a>
      <h1 class="font-display text-3xl font-normal leading-[1.2] tracking-tight md:text-4xl lg:text-[2.75rem]">
        {title}
      </h1>
      <p class="text-lg leading-relaxed text-[var(--color-muted)]">{description}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--color-muted)]">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {
          formattedUpdated && (
            <span>更新于 {formattedUpdated}</span>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full bg-[var(--color-surface)] px-3 py-1.5 text-xs text-[var(--color-muted)] transition hover:text-[var(--color-text)]"
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>
