---
interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

<figure class="diagram-frame" role="img">
  <div class="diagram-frame__canvas">
    <slot />
  </div>
  {caption && <figcaption class="diagram-frame__caption">{caption}</figcaption>}
</figure>

<style>
  .diagram-frame {
    margin: 1.75em 0;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    overflow: hidden;
  }

  .diagram-frame__canvas {
    padding: 1.25rem 1rem 1rem;
    overflow-x: auto;
  }

  .diagram-frame__canvas :global(svg) {
    display: block;
    width: 100%;
    min-width: 520px;
    height: auto;
  }

  .diagram-frame__caption {
    padding: 0.75rem 1.25rem 1rem;
    border-top: 1px solid var(--color-border-subtle);
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-align: center;
  }
</style>
