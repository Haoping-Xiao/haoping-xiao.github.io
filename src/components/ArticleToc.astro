---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 6);
---

{
  tocHeadings.length > 0 && (
    <nav class="article-toc" aria-label="文章目录">
      <details class="article-toc__panel">
        <summary class="article-toc__summary">
          <span class="article-toc__summary-text">本文目录</span>
          <span class="article-toc__summary-meta">{tocHeadings.length} 节</span>
        </summary>
        <div class="article-toc__inner">
          <p class="article-toc__kicker">On this page</p>
          <ol class="article-toc__list">
            {
              tocHeadings.map((heading, index) => (
                <li
                  class:list={['article-toc__item', { 'is-active': index === 0 }]}
                  style={`--depth: ${heading.depth - 2}`}
                >
                  <a href={`#${heading.slug}`} class="article-toc__link">
                    <span class="article-toc__marker" aria-hidden="true" />
                    <span class="article-toc__label">{heading.text}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </details>
    </nav>
  )
}

<script>
  function initArticleToc() {
    const toc = document.querySelector('.article-toc');
    if (!toc || toc.dataset.tocInit === 'true') return;
    toc.dataset.tocInit = 'true';

    const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('.article-toc__link'));
    if (links.length === 0) return;

    const headingMap = new Map<string, HTMLElement>();
    for (const link of links) {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) continue;
      const heading = document.getElementById(id);
      if (heading) headingMap.set(id, heading);
    }

    const headings = Array.from(headingMap.values());
    if (headings.length === 0) return;

    const setActive = (id: string) => {
      for (const link of links) {
        const item = link.closest('.article-toc__item');
        const isActive = link.getAttribute('href') === `#${id}`;
        item?.classList.toggle('is-active', isActive);
      }
    };

    const updateActive = () => {
      const offset = 96;
      let current = headings[0]?.id ?? '';

      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= offset) {
          current = heading.id;
        }
      }

      const nearBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 48;
      if (nearBottom) {
        current = headings[headings.length - 1]?.id ?? current;
      }

      if (current) setActive(current);
    };

    const observer = new IntersectionObserver(
      () => updateActive(),
      { rootMargin: '-96px 0px -55% 0px', threshold: [0, 0.25, 0.5, 1] },
    );

    for (const heading of headings) observer.observe(heading);
    updateActive();
    window.addEventListener('scroll', updateActive, { passive: true });
  }

  initArticleToc();
  document.addEventListener('astro:page-load', initArticleToc);
</script>
