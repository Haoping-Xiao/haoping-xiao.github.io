---
/** 博客页 Mermaid 渲染脚本 */
---

<script>
  import mermaid from 'mermaid';

  let initialized = false;

  function ensureMermaid() {
    if (initialized) return;
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'strict',
      fontFamily: '"Noto Sans SC", "Source Sans 3", sans-serif',
      theme: 'base',
      themeVariables: {
        primaryColor: '#f5f4ed',
        primaryTextColor: '#141413',
        primaryBorderColor: '#d1cfc5',
        lineColor: '#d97757',
        secondaryColor: '#faf9f5',
        tertiaryColor: '#f0eee6',
        fontFamily: '"Noto Sans SC", "Source Sans 3", sans-serif',
        noteBkgColor: '#f0eee6',
        noteTextColor: '#87867f',
        actorBkg: '#faf9f5',
        actorBorder: '#d1cfc5',
        actorTextColor: '#141413',
        signalColor: '#141413',
        signalTextColor: '#141413',
      },
    });
    initialized = true;
  }

  function decodeBase64Utf8(encoded: string) {
    const binary = atob(encoded);
    const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
    return new TextDecoder().decode(bytes);
  }

  async function renderDiagram(root: HTMLElement) {
    const preview = root.querySelector<HTMLElement>('[data-diagram-preview]');
    const loading = root.querySelector<HTMLElement>('[data-diagram-loading]');
    if (!preview || root.dataset.rendered === 'true') return;

    const encoded = preview.dataset.diagramSource;
    if (!encoded) return;

    const code = decodeBase64Utf8(encoded).trim();
    if (!code) return;

    ensureMermaid();

    try {
      const { svg } = await mermaid.render(`${root.dataset.diagramId}-svg`, code);
      loading?.remove();
      const wrapper = document.createElement('div');
      wrapper.className = 'text-diagram__svg';
      wrapper.innerHTML = svg;
      preview.appendChild(wrapper);
      root.dataset.rendered = 'true';
    } catch (error) {
      if (loading) loading.textContent = '图表渲染失败';
      console.error('Mermaid render failed:', error);
    }
  }

  function initAll() {
    document.querySelectorAll<HTMLElement>('[data-text-diagram]').forEach((root) => {
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';
      void renderDiagram(root);
    });
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>
