---
import ContactLinks from './ContactLinks.astro';

const year = new Date().getFullYear();
---

<footer class="relative z-50 border-t border-[var(--color-dark-surface)] bg-[var(--color-dark)] text-[var(--color-bg)]">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-5 px-6 py-12 text-center text-sm text-[var(--color-muted-light)]">
    <ContactLinks variant="dark" />
    <p>记录 AI 领域的学习、思考与实践</p>
    <p>&copy; {year} Haoping</p>
  </div>
</footer>
