---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]/50">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-3 px-6 py-10 text-center text-sm text-[var(--color-muted)]">
    <p>记录 AI Agent 领域的探索与思考</p>
    <p>
      &copy; {year}
      <a
        href="https://github.com/haoping-xiao"
        class="text-[var(--color-accent)] transition hover:text-[var(--color-warm)]"
        target="_blank"
        rel="noopener noreferrer"
      >
        haoping-xiao
      </a>
    </p>
  </div>
</footer>
