---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-dark-surface)] bg-[var(--color-dark)] text-[var(--color-bg)]">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-6 py-12 text-center text-sm text-[var(--color-muted-light)]">
    <p>记录 AI Agent 领域的探索与思考</p>
    <p>
      &copy; {year}
      <a
        href="https://github.com/haoping-xiao"
        class="text-[var(--color-accent)] transition hover:text-[var(--color-accent-hover)]"
        target="_blank"
        rel="noopener noreferrer"
      >
        haoping-xiao
      </a>
    </p>
  </div>
</footer>
