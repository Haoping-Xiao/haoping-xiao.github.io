---
interface Props {
  size?: number;
  class?: string;
}

const { size = 28, class: className = '' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 32 32"
  fill="none"
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
>
  <rect width="32" height="32" rx="7" fill="#faf9f5" stroke="#e8e6dc" stroke-width="0.75"></rect>
  <path d="M10 23V9" stroke="#141413" stroke-width="2.25" stroke-linecap="round"></path>
  <path d="M20 23V13" stroke="#141413" stroke-width="2.25" stroke-linecap="round"></path>
  <path d="M10 15.5h10" stroke="#141413" stroke-width="2.25" stroke-linecap="round"></path>
  <path d="M20 13c2.5-1.5 4.5-4 5.5-7" stroke="#d97757" stroke-width="2" stroke-linecap="round"></path>
  <circle cx="26" cy="5.5" r="1.75" fill="#d97757"></circle>
</svg>
