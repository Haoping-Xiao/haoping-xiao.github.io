---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  postsPerPage?: number;
}

const { posts, postsPerPage = 10 } = Astro.props;

const techDomains = [...new Set(posts.flatMap((p) => p.data.techDomain))].sort(
  (a, b) => a.localeCompare(b, 'zh-CN')
);
const products = [...new Set(posts.flatMap((p) => p.data.product))].sort((a, b) =>
  a.localeCompare(b, 'zh-CN')
);
const topics = [...new Set(posts.flatMap((p) => p.data.topic))].sort((a, b) =>
  a.localeCompare(b, 'zh-CN')
);

const postsData = posts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate.toISOString(),
  techDomain: post.data.techDomain ?? [],
  product: post.data.product ?? [],
  topic: post.data.topic ?? [],
}));
---

<section class="mx-auto max-w-6xl px-6 py-12 md:py-16" id="blog-explorer">
  <div class="flex flex-col gap-8 lg:flex-row lg:gap-12">
    <!-- Sidebar: Filter & Sort -->
    <aside id="filter-sidebar" class="hidden w-full shrink-0 lg:w-52" aria-label="筛选与排序">
      <h2 class="mb-5 text-xs font-medium uppercase tracking-widest text-[var(--color-muted)]">
        筛选与排序
      </h2>

      <div class="space-y-6">
        <div>
          <label for="sort-select" class="mb-2 block text-sm font-medium text-[var(--color-text)]">
            排序方式
          </label>
          <select
            id="sort-select"
            class="w-full appearance-none rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-bg)] px-3 py-2.5 text-sm text-[var(--color-text)] outline-none transition focus:border-[var(--color-border)]"
          >
            <option value="newest">最新发布</option>
            <option value="alphabetical">字母排序</option>
          </select>
        </div>

        {
          techDomains.length > 0 && (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-medium text-[var(--color-text)] [&::-webkit-details-marker]:hidden">
                技术领域
                <svg class="h-4 w-4 text-[var(--color-muted)] transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="mt-3 space-y-2.5">
                {techDomains.map((domain) => (
                  <label class="flex cursor-pointer items-center gap-2.5 text-sm text-[var(--color-muted)] transition hover:text-[var(--color-text)]">
                    <input
                      type="checkbox"
                      name="techDomain"
                      value={domain}
                      class="h-4 w-4 rounded border-[var(--color-border)] accent-[var(--color-accent)]"
                    />
                    {domain}
                  </label>
                ))}
              </div>
            </details>
          )
        }

        {
          products.length > 0 && (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-medium text-[var(--color-text)] [&::-webkit-details-marker]:hidden">
                产品
                <svg class="h-4 w-4 text-[var(--color-muted)] transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="mt-3 space-y-2.5">
                {products.map((item) => (
                  <label class="flex cursor-pointer items-center gap-2.5 text-sm text-[var(--color-muted)] transition hover:text-[var(--color-text)]">
                    <input
                      type="checkbox"
                      name="product"
                      value={item}
                      class="h-4 w-4 rounded border-[var(--color-border)] accent-[var(--color-accent)]"
                    />
                    {item}
                  </label>
                ))}
              </div>
            </details>
          )
        }

        {
          topics.length > 0 && (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-center justify-between text-sm font-medium text-[var(--color-text)] [&::-webkit-details-marker]:hidden">
                主题
                <svg class="h-4 w-4 text-[var(--color-muted)] transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="mt-3 space-y-2.5">
                {topics.map((item) => (
                  <label class="flex cursor-pointer items-center gap-2.5 text-sm text-[var(--color-muted)] transition hover:text-[var(--color-text)]">
                    <input
                      type="checkbox"
                      name="topic"
                      value={item}
                      class="h-4 w-4 rounded border-[var(--color-border)] accent-[var(--color-accent)]"
                    />
                    {item}
                  </label>
                ))}
              </div>
            </details>
          )
        }
      </div>
    </aside>

    <!-- Main content -->
    <div class="min-w-0 flex-1">
      <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <button
          type="button"
          id="filter-toggle"
          class="inline-flex shrink-0 items-center gap-2 rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-bg)] px-3 py-2.5 text-sm text-[var(--color-muted)] transition hover:border-[var(--color-border)] hover:text-[var(--color-text)]"
          aria-expanded="false"
          aria-controls="filter-sidebar"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <rect x="3" y="4" width="18" height="16" rx="2"></rect>
            <path stroke-linecap="round" d="M9 4v16"></path>
          </svg>
          <span id="filter-toggle-label">显示筛选</span>
        </button>

        <div class="relative min-w-0 flex-1">
          <svg
            class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--color-muted)]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="search"
            id="search-input"
            placeholder="搜索文章"
            class="w-full rounded-full border border-[var(--color-border-subtle)] bg-[var(--color-bg)] py-3 pl-11 pr-4 text-sm text-[var(--color-text)] outline-none transition placeholder:text-[var(--color-muted-light)] focus:border-[var(--color-border)]"
          />
        </div>
      </div>

      <div id="post-list" class="flex flex-col gap-4">
        {
          posts.map((post) => (
            <div
              class="post-item"
              data-id={post.id}
              data-title={post.data.title}
              data-description={post.data.description}
              data-pubdate={post.data.pubDate.toISOString()}
              data-tech-domain={post.data.techDomain?.join(',') ?? ''}
              data-product={post.data.product?.join(',') ?? ''}
              data-topic={post.data.topic?.join(',') ?? ''}
            >
              <PostCard post={post} variant="list" />
            </div>
          ))
        }
      </div>

      <p id="empty-state" class="hidden py-16 text-center text-sm text-[var(--color-muted)]">
        没有找到匹配的文章
      </p>

      <nav id="pagination" class="mt-10 flex items-center justify-center gap-2" aria-label="分页导航">
      </nav>
    </div>
  </div>
</section>

<script define:vars={{ postsData, postsPerPage }}>
  const explorer = document.getElementById('blog-explorer');
  if (!explorer) throw new Error('Blog explorer not found');

  const filterSidebar = document.getElementById('filter-sidebar');
  const filterToggle = document.getElementById('filter-toggle');
  const filterToggleLabel = document.getElementById('filter-toggle-label');
  const searchInput = document.getElementById('search-input');
  const sortSelect = document.getElementById('sort-select');
  const postList = document.getElementById('post-list');
  const emptyState = document.getElementById('empty-state');
  const pagination = document.getElementById('pagination');

  const FILTER_VISIBILITY_KEY = 'blog-explorer-filters-visible';

  function setFiltersVisible(visible) {
    filterSidebar.classList.toggle('hidden', !visible);
    filterToggle.setAttribute('aria-expanded', String(visible));
    filterToggleLabel.textContent = visible ? '隐藏筛选' : '显示筛选';

    try {
      localStorage.setItem(FILTER_VISIBILITY_KEY, visible ? '1' : '0');
    } catch {}
  }

  function initFiltersVisibility() {
    let visible = false;

    try {
      const stored = localStorage.getItem(FILTER_VISIBILITY_KEY);
      if (stored !== null) visible = stored === '1';
    } catch {}

    setFiltersVisible(visible);
  }

  filterToggle.addEventListener('click', () => {
    setFiltersVisible(filterSidebar.classList.contains('hidden'));
  });

  initFiltersVisibility();

  let currentPage = 1;
  let searchMatchIds = null;
  let searchDebounceTimer;
  let pagefindModule = null;
  let pagefindReady = false;

  function postIdFromUrl(url) {
    const path = url.startsWith('http') ? new URL(url).pathname : url;
    const match = path.match(/\/blog\/([^/]+)\/?$/);
    return match ? match[1] : null;
  }

  async function ensurePagefind() {
    if (pagefindReady) return pagefindModule;
    try {
      pagefindModule = await import('/pagefind/pagefind.js');
      await pagefindModule.options({});
      pagefindReady = true;
      return pagefindModule;
    } catch {
      return null;
    }
  }

  async function resolveSearchIds(query) {
    if (!query) return null;

    const pagefind = await ensurePagefind();
    if (!pagefind) {
      const lowerQuery = query.toLowerCase();
      return new Set(
        postsData
          .filter((post) => `${post.title} ${post.description}`.toLowerCase().includes(lowerQuery))
          .map((post) => post.id)
      );
    }

    const response = await pagefind.search(query);
    const details = await Promise.all(response.results.map((result) => result.data()));
    const ids = new Set();

    for (const data of details) {
      const id = postIdFromUrl(data.url);
      if (id) ids.add(id);
    }

    return ids;
  }

  function getSelectedFilters(name) {
    return Array.from(explorer.querySelectorAll(`input[name="${name}"]:checked`)).map(
      (el) => el.value
    );
  }

  function getFilteredPosts() {
    const sort = sortSelect.value;
    const techDomains = getSelectedFilters('techDomain');
    const products = getSelectedFilters('product');
    const topics = getSelectedFilters('topic');

    let filtered = postsData.filter((post) => {
      if (searchMatchIds !== null && !searchMatchIds.has(post.id)) return false;
      if (techDomains.length > 0) {
        if (!techDomains.some((d) => post.techDomain.includes(d))) return false;
      }
      if (products.length > 0) {
        if (!products.some((p) => post.product.includes(p))) return false;
      }
      if (topics.length > 0) {
        if (!topics.some((t) => post.topic.includes(t))) return false;
      }
      return true;
    });

    if (sort === 'newest') {
      filtered.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));
    } else {
      filtered.sort((a, b) => a.title.localeCompare(b.title, 'zh-CN'));
    }

    return filtered;
  }

  function renderPagination(totalPages) {
    pagination.innerHTML = '';
    if (totalPages <= 1) return;

    const prevBtn = document.createElement('button');
    prevBtn.textContent = '上一页';
    prevBtn.disabled = currentPage === 1;
    prevBtn.className =
      'rounded-lg border border-[var(--color-border-subtle)] px-3 py-1.5 text-sm text-[var(--color-muted)] transition hover:border-[var(--color-border)] hover:text-[var(--color-text)] disabled:cursor-not-allowed disabled:opacity-40';
    prevBtn.addEventListener('click', () => {
      currentPage--;
      updateView();
    });
    pagination.appendChild(prevBtn);

    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.textContent = String(i);
      btn.className =
        i === currentPage
          ? 'rounded-lg bg-[var(--color-text)] px-3 py-1.5 text-sm text-[var(--color-bg)]'
          : 'rounded-lg border border-[var(--color-border-subtle)] px-3 py-1.5 text-sm text-[var(--color-muted)] transition hover:border-[var(--color-border)] hover:text-[var(--color-text)]';
      btn.addEventListener('click', () => {
        currentPage = i;
        updateView();
      });
      pagination.appendChild(btn);
    }

    const nextBtn = document.createElement('button');
    nextBtn.textContent = '下一页';
    nextBtn.disabled = currentPage === totalPages;
    nextBtn.className =
      'rounded-lg border border-[var(--color-border-subtle)] px-3 py-1.5 text-sm text-[var(--color-muted)] transition hover:border-[var(--color-border)] hover:text-[var(--color-text)] disabled:cursor-not-allowed disabled:opacity-40';
    nextBtn.addEventListener('click', () => {
      currentPage++;
      updateView();
    });
    pagination.appendChild(nextBtn);
  }

  function updateView() {
    const filtered = getFilteredPosts();
    const totalPages = Math.max(1, Math.ceil(filtered.length / postsPerPage));

    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * postsPerPage;
    const pageIds = new Set(filtered.slice(start, start + postsPerPage).map((p) => p.id));
    const filteredIds = new Set(filtered.map((p) => p.id));

    const itemMap = new Map();
    postList.querySelectorAll('.post-item').forEach((item) => {
      itemMap.set(item.dataset.id, item);
    });

    filtered.forEach((post) => {
      const item = itemMap.get(post.id);
      if (item) postList.appendChild(item);
    });

    itemMap.forEach((item, id) => {
      if (!filteredIds.has(id)) {
        item.classList.add('hidden');
      } else {
        item.classList.toggle('hidden', !pageIds.has(id));
      }
    });

    const hasResults = filtered.length > 0;
    emptyState.classList.toggle('hidden', hasResults);
    postList.classList.toggle('hidden', !hasResults);

    renderPagination(totalPages);
  }

  searchInput.addEventListener('input', () => {
    currentPage = 1;
    clearTimeout(searchDebounceTimer);
    const query = searchInput.value.trim();

    searchDebounceTimer = setTimeout(async () => {
      searchMatchIds = await resolveSearchIds(query);
      updateView();
    }, 250);
  });
  sortSelect.addEventListener('change', () => {
    currentPage = 1;
    updateView();
  });
  explorer.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
    cb.addEventListener('change', () => {
      currentPage = 1;
      updateView();
    });
  });

  updateView();
</script>
