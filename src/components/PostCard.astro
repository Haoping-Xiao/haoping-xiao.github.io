---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface-hover)]">
  <a href={`/blog/${post.id}`} class="block space-y-3">
    <time class="text-xs font-medium tracking-wide text-[var(--color-accent)] uppercase">
      {formattedDate}
    </time>
    <h2 class="font-display text-xl font-semibold leading-snug transition group-hover:text-[var(--color-accent)]">
      {title}
    </h2>
    <p class="line-clamp-2 text-sm leading-relaxed text-[var(--color-muted)]">
      {description}
    </p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-1">
          {tags.map((tag) => (
            <span class="rounded-full bg-[var(--color-bg)] px-2.5 py-0.5 text-xs text-[var(--color-muted)] ring-1 ring-[var(--color-border)]">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </a>
</article>
