---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formattedDate = pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group rounded-2xl border border-[var(--color-border-subtle)] bg-[var(--color-bg)] p-6 transition hover:border-[var(--color-border)]">
  <a href={`/blog/${post.id}`} class="flex h-full flex-col gap-4">
    <time class="text-sm text-[var(--color-muted)]">
      {formattedDate}
    </time>
    <h2 class="font-display text-xl font-medium leading-snug tracking-tight transition group-hover:text-[var(--color-accent)]">
      {title}
    </h2>
    <p class="line-clamp-2 flex-1 text-sm leading-relaxed text-[var(--color-muted)]">
      {description}
    </p>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 pt-1">
          {tags.map((tag) => (
            <span class="rounded-full bg-[var(--color-surface)] px-3 py-1 text-xs text-[var(--color-muted)]">
              {tag}
            </span>
          ))}
        </div>
      )
    }
    <span class="text-sm font-medium text-[var(--color-accent)] transition group-hover:text-[var(--color-accent-hover)]">
      阅读全文 →
    </span>
  </a>
</article>
